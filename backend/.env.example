# Server
PORT=5050
FRONTEND_ORIGIN=http://localhost:3000

# Postgres (local install)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pm_suite
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password

# Encrypts each AWS account's secret key before it's stored in Postgres.
# Generate with:  openssl rand -hex 32
# This is NOT an AWS credential itself - it's the local key that protects
# the AWS credentials you'll enter per-account inside the app UI.
ENCRYPTION_KEY=

# Auth for this dashboard (separate from any AWS/company IAM login)
JWT_SECRET=replace_with_a_long_random_string
ADMIN_EMAIL=you@company.com
# Generate with: npm run hash-password -- "yourPassword"
ADMIN_PASSWORD_HASH=

# How often to auto-pull AWS costs into billing_history for every connected
# account (cron syntax). Default: once a day at 2am.
COST_SYNC_CRON=0 2 * * *

# NOTE: There is intentionally no AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
# Each AWS account's keys are entered through the app UI (Add/Edit AWS Account)
# and stored encrypted per-account in Postgres - this is what lets you connect
# multiple AWS accounts (Account 1, 2, 3...) at the same time, each with its
# own credentials, instead of one shared key for everything.
